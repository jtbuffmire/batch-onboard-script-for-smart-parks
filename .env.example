# ChirpStack credentials for batch-onboard-us915.py
#
# To use:
#   1. Copy this file to ./.env (cp .env.example .env)
#   2. Fill in the three values below
#   3. Run ./batch-onboard.sh
#
# Or skip this file entirely and let the wizard prompt you on first run --
# it will offer to save your answers to ./.env for next time.

# Base URL of your ChirpStack v4 instance (no trailing slash).
CHIRPSTACK_BASE_URL=https://your-chirpstack.example.com

# An API key with at least read access to the application below.
# Create one in the ChirpStack UI under Tenants -> [your tenant] -> API keys.
CHIRPSTACK_API_KEY=your-api-key-here

# UUID of the application your devices belong to.
# Find it in the URL when viewing the application in ChirpStack:
#   https://.../#/tenants/{tenant_id}/applications/{this_uuid}
CHIRPSTACK_APPLICATION_ID=00000000-0000-0000-0000-000000000000
